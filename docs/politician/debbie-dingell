<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Debbie Dingell | Congress Tracker</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/static/style.css"/>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="logo">
      <span class="logo-icon">C</span>
      <span class="logo-text">Congress<span class="logo-accent">Tracker</span></span>
    </a>
    <a href="/?tab=politicians" class="back-link">&#8592; All Members</a>
  </div>
</nav>

<main class="container politician-page">

  <!-- ─── PROFILE HEADER ─── -->
  <div class="profile-header-v2">

    <!-- Left: photo + status -->
    <div class="profile-left">
      <div class="profile-photo-circle dem-border">
        
        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/9/98/Debbie_Dingell_Official_Headshot.jpg/250px-Debbie_Dingell_Official_Headshot.jpg" alt="Debbie Dingell" class="profile-photo-img"
             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"/>
        <div class="profile-photo-fallback-circ" style="display:none">D</div>
        
      </div>
      <div class="profile-status-pill">
        <span class="status-dot"></span>
        Active
      </div>
      
    </div>

    <!-- Right: info -->
    <div class="profile-right">
      <div class="profile-name-row">
        <h1 class="profile-name">Debbie Dingell</h1>
        <span class="party-badge-lg dem">
          Democrat
        </span>
      </div>

      <div class="profile-meta-row">
        <span class="profile-meta-item">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          House
        </span>
        
        <span class="profile-meta-item">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
          MI – District 6
        </span>
        
      </div>

      <!-- Stats strip -->
      <div class="profile-stats-strip">
        <div class="pstat">
          <span class="pstat-val">5</span>
          <span class="pstat-label">Total Trades</span>
        </div>
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val">$81,004</span>
          <span class="pstat-label">Total Volume</span>
        </div>
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val green">2</span>
          <span class="pstat-label">Buys</span>
        </div>
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val red">3</span>
          <span class="pstat-label">Sells</span>
        </div>
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val">2025-11-24</span>
          <span class="pstat-label">Last Trade</span>
        </div>
        
        
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val green">10.6d</span>
          <span class="pstat-label">Avg Delay</span>
        </div>
        
      </div>

      <!-- Top tickers -->
      
      <div class="profile-tickers-row">
        <span class="tickers-label">Most traded:</span>
        
        <span class="ticker-pill lg">DIS <small>×1</small></span>
        
        <span class="ticker-pill lg">WMT <small>×1</small></span>
        
        <span class="ticker-pill lg">HON <small>×1</small></span>
        
        <span class="ticker-pill lg">GOOGL <small>×1</small></span>
        
        <span class="ticker-pill lg">AAPL <small>×1</small></span>
        
      </div>
      
    </div>
  </div>

  <!-- ─── TRADE HISTORY TABLE ─── -->
  <div class="trades-section">
    <div class="trades-section-header">
      <h2>Trade History <span class="trades-count">5</span></h2>
      
      <div class="profile-type-summary">
        <span class="type-badge buy">2 BUY</span>
        <span class="type-badge sell">3 SELL</span>
        <span class="buy-pct-pill">40% buy ratio</span>
      </div>
      
    </div>

    
    <div class="trades-table-wrap" style="max-height: 700px">
      <table class="trades-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Ticker</th>
            <th>Asset</th>
            <th>Type</th>
            <th>Amount</th>
            <th>Filing Delay</th>
          </tr>
        </thead>
        <tbody>
          
          <tr>
            <td class="muted">2025-11-24</td>
            <td><strong class="ticker">HON</strong></td>
            <td class="muted asset-cell" title="Honeywell International Inc">
              Honeywell International Inc
            </td>
            <td><span class="type-badge sell">SELL</span></td>
            <td class="muted">$15,001 - $50,000</td>
            <td>
              
              <span class="green">14d</span>
              
            </td>
          </tr>
          
          <tr>
            <td class="muted">2025-11-24</td>
            <td><strong class="ticker">GOOGL</strong></td>
            <td class="muted asset-cell" title="Alphabet Inc">
              Alphabet Inc
            </td>
            <td><span class="type-badge sell">SELL</span></td>
            <td class="muted">$15,001 - $50,000</td>
            <td>
              
              <span class="green">14d</span>
              
            </td>
          </tr>
          
          <tr>
            <td class="muted">2025-11-24</td>
            <td><strong class="ticker">AAPL</strong></td>
            <td class="muted asset-cell" title="Apple Inc">
              Apple Inc
            </td>
            <td><span class="type-badge sell">SELL</span></td>
            <td class="muted">$50,001 - $100,000</td>
            <td>
              
              <span class="green">14d</span>
              
            </td>
          </tr>
          
          <tr>
            <td class="muted">2025-03-27</td>
            <td><strong class="ticker">WMT</strong></td>
            <td class="muted asset-cell" title="Walmart Inc. Common Stock">
              Walmart Inc. Common Stock
            </td>
            <td><span class="type-badge buy">BUY</span></td>
            <td class="muted">$15,001 -</td>
            <td>
              
              <span class="green">4d</span>
              
            </td>
          </tr>
          
          <tr>
            <td class="muted">2025-01-15</td>
            <td><strong class="ticker">DIS</strong></td>
            <td class="muted asset-cell" title="Walt Disney Company">
              Walt Disney Company
            </td>
            <td><span class="type-badge buy">BUY</span></td>
            <td class="muted">$1,001 - $15,000</td>
            <td>
              
              <span class="green">7d</span>
              
            </td>
          </tr>
          
        </tbody>
      </table>
    </div>
    
  </div>

</main>

<footer class="footer">
  <div class="container">
    <p>Data: Official House Clerk PTR disclosures | InsiderFinance | Quiver Quantitative</p>
  </div>
</footer>

</body>
</html>