<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Michael Patrick Guest | Congress Tracker</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/static/style.css"/>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="logo">
      <span class="logo-icon">C</span>
      <span class="logo-text">Congress<span class="logo-accent">Tracker</span></span>
    </a>
    <a href="/?tab=politicians" class="back-link">&#8592; All Members</a>
  </div>
</nav>

<main class="container politician-page">

  <!-- ─── PROFILE HEADER ─── -->
  <div class="profile-header-v2">

    <!-- Left: photo + status -->
    <div class="profile-left">
      <div class="profile-photo-circle rep-border">
        
        <img src="https://theunitedstates.io/images/congress/225x275/G000591.jpg" alt="Michael Patrick Guest" class="profile-photo-img"
             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"/>
        <div class="profile-photo-fallback-circ" style="display:none">M</div>
        
      </div>
      <div class="profile-status-pill">
        <span class="status-dot"></span>
        Active
      </div>
      
    </div>

    <!-- Right: info -->
    <div class="profile-right">
      <div class="profile-name-row">
        <h1 class="profile-name">Michael Patrick Guest</h1>
        <span class="party-badge-lg rep">
          Republican
        </span>
      </div>

      <div class="profile-meta-row">
        <span class="profile-meta-item">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Representatives
        </span>
        
      </div>

      <!-- Stats strip -->
      <div class="profile-stats-strip">
        <div class="pstat">
          <span class="pstat-val">4</span>
          <span class="pstat-label">Total Trades</span>
        </div>
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val">$4,004</span>
          <span class="pstat-label">Total Volume</span>
        </div>
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val green">1</span>
          <span class="pstat-label">Buys</span>
        </div>
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val red">3</span>
          <span class="pstat-label">Sells</span>
        </div>
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val">2026-01-09</span>
          <span class="pstat-label">Last Trade</span>
        </div>
        
        
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val red">37.5d</span>
          <span class="pstat-label">Avg Delay</span>
        </div>
        
      </div>

      <!-- Top tickers -->
      
      <div class="profile-tickers-row">
        <span class="tickers-label">Most traded:</span>
        
        <span class="ticker-pill lg">EVVTY <small>×1</small></span>
        
        <span class="ticker-pill lg">DT <small>×1</small></span>
        
        <span class="ticker-pill lg">CHRD <small>×1</small></span>
        
        <span class="ticker-pill lg">MPWR <small>×1</small></span>
        
      </div>
      
    </div>
  </div>

  <!-- ─── TRADE HISTORY TABLE ─── -->
  <div class="trades-section">
    <div class="trades-section-header">
      <h2>Trade History <span class="trades-count">4</span></h2>
      
      <div class="profile-type-summary">
        <span class="type-badge buy">1 BUY</span>
        <span class="type-badge sell">3 SELL</span>
        <span class="buy-pct-pill">25% buy ratio</span>
      </div>
      
    </div>

    
    <div class="trades-table-wrap" style="max-height: 700px">
      <table class="trades-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Ticker</th>
            <th>Asset</th>
            <th>Type</th>
            <th>Amount</th>
            <th>Filing Delay</th>
          </tr>
        </thead>
        <tbody>
          
          <tr>
            <td class="muted">2026-01-09</td>
            <td><strong class="ticker">EVVTY</strong></td>
            <td class="muted asset-cell" title="">
              —
            </td>
            <td><span class="type-badge sell">SELL</span></td>
            <td class="muted">$1,001 - $15,000</td>
            <td>
              
              <span class="red">39d</span>
              
            </td>
          </tr>
          
          <tr>
            <td class="muted">2026-01-09</td>
            <td><strong class="ticker">DT</strong></td>
            <td class="muted asset-cell" title="Dynatrace Inc">
              Dynatrace Inc
            </td>
            <td><span class="type-badge sell">SELL</span></td>
            <td class="muted">$1,001 - $15,000</td>
            <td>
              
              <span class="red">40d</span>
              
            </td>
          </tr>
          
          <tr>
            <td class="muted">2026-01-09</td>
            <td><strong class="ticker">CHRD</strong></td>
            <td class="muted asset-cell" title="Chord Energy Corp">
              Chord Energy Corp
            </td>
            <td><span class="type-badge sell">SELL</span></td>
            <td class="muted">$1,001 - $15,000</td>
            <td>
              
              <span class="red">40d</span>
              
            </td>
          </tr>
          
          <tr>
            <td class="muted">2025-10-20</td>
            <td><strong class="ticker">MPWR</strong></td>
            <td class="muted asset-cell" title="Monolithic Power Systems Inc">
              Monolithic Power Systems Inc
            </td>
            <td><span class="type-badge buy">BUY</span></td>
            <td class="muted">$1,001 - $15,000</td>
            <td>
              
              <span class="yellow">31d</span>
              
            </td>
          </tr>
          
        </tbody>
      </table>
    </div>
    
  </div>

</main>

<footer class="footer">
  <div class="container">
    <p>Data: Official House Clerk PTR disclosures | InsiderFinance | Quiver Quantitative</p>
  </div>
</footer>

</body>
</html>