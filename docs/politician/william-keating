            <td class="muted">$1,001 - $15,000</td>
            <td>
              
              <span class="yellow">23d</span>
              
            </td>
          </tr>
          
          <tr>
            <td class="muted">2025-12-05</td>
            <td><strong class="ticker">CMCSA</strong></td>
            <td class="muted asset-cell" title="Comcast Corp">
              Comcast Corp
            </td>
            <td><span class="type-badge sell">SELL</span></td>
            <td class="muted">$1,001 - $15,000</td>
            <td>
              
              <span class="green">12d</span>
              
            </td>
          </tr>
          
          <tr>
            <td class="muted">2025-02-05</td>
