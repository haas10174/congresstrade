<body>

<!-- NAV -->
<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="logo">
      <span class="logo-icon">C</span>
      <span class="logo-text">Congress<span class="logo-accent">Tracker</span></span>
    </a>
    <a href="/?tab=politicians" class="back-link">&#8592; All Members</a>
  </div>
</nav>

<main class="container politician-page">

  <!-- ─── PROFILE HEADER ─── -->
  <div class="profile-header-v2">

    <!-- Left: photo + status -->
    <div class="profile-left">
      <div class="profile-photo-circle rep-border">
        
        <img src="https://theunitedstates.io/images/congress/225x275/K000398.jpg" alt="Thomas H. Kean Jr" class="profile-photo-img"
             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"/>
        <div class="profile-photo-fallback-circ" style="display:none">T</div>
        
      </div>
      <div class="profile-status-pill">
        <span class="status-dot"></span>
        Active
      </div>
      
    </div>

    <!-- Right: info -->
    <div class="profile-right">
      <div class="profile-name-row">
        <h1 class="profile-name">Thomas H. Kean Jr</h1>
        <span class="party-badge-lg rep">
          Republican
        </span>
      </div>

      <div class="profile-meta-row">
        <span class="profile-meta-item">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Representatives
        </span>
        
      </div>

      <!-- Stats strip -->
      <div class="profile-stats-strip">
        <div class="pstat">
          <span class="pstat-val">9</span>
          <span class="pstat-label">Total Trades</span>
        </div>
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val">$65,009</span>
          <span class="pstat-label">Total Volume</span>
        </div>
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val green">3</span>
          <span class="pstat-label">Buys</span>
        </div>
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val red">6</span>
          <span class="pstat-label">Sells</span>
        </div>
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val">2026-02-18</span>
          <span class="pstat-label">Last Trade</span>
        </div>
        
        
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val yellow">30.2d</span>
          <span class="pstat-label">Avg Delay</span>
        </div>
        
      </div>

      <!-- Top tickers -->
      
      <div class="profile-tickers-row">
        <span class="tickers-label">Most traded:</span>
        
        <span class="ticker-pill lg">LIN <small>×1</small></span>
        
        <span class="ticker-pill lg">WAT <small>×1</small></span>
        
        <span class="ticker-pill lg">GOOGL <small>×1</small></span>
        
        <span class="ticker-pill lg">FCNCA <small>×1</small></span>
        
        <span class="ticker-pill lg">ABT <small>×1</small></span>
        
      </div>
      
    </div>
  </div>

  <!-- ─── TRADE HISTORY TABLE ─── -->
