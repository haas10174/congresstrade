    <div class="trades-section-header">
      <h2>Trade History <span class="trades-count">9</span></h2>
      
      <div class="profile-type-summary">
        <span class="type-badge buy">3 BUY</span>
        <span class="type-badge sell">6 SELL</span>
        <span class="buy-pct-pill">33% buy ratio</span>
