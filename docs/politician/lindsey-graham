        </div>
        
        
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val red">35.2d</span>
          <span class="pstat-label">Avg Delay</span>
        </div>
        
      </div>

      <!-- Top tickers -->
      
