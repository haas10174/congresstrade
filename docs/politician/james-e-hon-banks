<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>James E Hon Banks | Congress Tracker</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/static/style.css"/>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="logo">
      <span class="logo-icon">C</span>
      <span class="logo-text">Congress<span class="logo-accent">Tracker</span></span>
    </a>
    <a href="/?tab=politicians" class="back-link">&#8592; All Members</a>
  </div>
</nav>

<main class="container politician-page">

  <!-- ─── PROFILE HEADER ─── -->
  <div class="profile-header-v2">

    <!-- Left: photo + status -->
    <div class="profile-left">
      <div class="profile-photo-circle rep-border">
        
        <div class="profile-photo-fallback-circ">J</div>
        
      </div>
      <div class="profile-status-pill">
        <span class="status-dot"></span>
        Active
      </div>
      
    </div>

    <!-- Right: info -->
    <div class="profile-right">
      <div class="profile-name-row">
        <h1 class="profile-name">James E Hon Banks</h1>
        <span class="party-badge-lg rep">
          Republican
        </span>
      </div>

      <div class="profile-meta-row">
        <span class="profile-meta-item">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Senate
        </span>
        
      </div>

      <!-- Stats strip -->
      <div class="profile-stats-strip">
        <div class="pstat">
          <span class="pstat-val">3</span>
          <span class="pstat-label">Total Trades</span>
        </div>
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val">$3,003</span>
          <span class="pstat-label">Total Volume</span>
        </div>
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val green">1</span>
          <span class="pstat-label">Buys</span>
        </div>
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val red">2</span>
          <span class="pstat-label">Sells</span>
        </div>
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val">2025-08-04</span>
          <span class="pstat-label">Last Trade</span>
        </div>
        
        
        <div class="pstat-divider"></div>
        <div class="pstat">
          <span class="pstat-val green">11.7d</span>
          <span class="pstat-label">Avg Delay</span>
        </div>
        
      </div>

      <!-- Top tickers -->
      
      <div class="profile-tickers-row">
        <span class="tickers-label">Most traded:</span>
        
        <span class="ticker-pill lg">SBUX <small>×1</small></span>
        
        <span class="ticker-pill lg">RBLX <small>×1</small></span>
        
        <span class="ticker-pill lg">YUM <small>×1</small></span>
        
      </div>
      
    </div>
  </div>

  <!-- ─── TRADE HISTORY TABLE ─── -->
  <div class="trades-section">
    <div class="trades-section-header">
      <h2>Trade History <span class="trades-count">3</span></h2>
      
      <div class="profile-type-summary">
        <span class="type-badge buy">1 BUY</span>
        <span class="type-badge sell">2 SELL</span>
        <span class="buy-pct-pill">33% buy ratio</span>
      </div>
      
    </div>

    
    <div class="trades-table-wrap" style="max-height: 700px">
      <table class="trades-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Ticker</th>
            <th>Asset</th>
            <th>Type</th>
            <th>Amount</th>
            <th>Filing Delay</th>
          </tr>
        </thead>
        <tbody>
          
          <tr>
            <td class="muted">2025-08-04</td>
            <td><strong class="ticker">SBUX</strong></td>
            <td class="muted asset-cell" title="Starbucks Corp">
              Starbucks Corp
            </td>
            <td><span class="type-badge buy">BUY</span></td>
            <td class="muted">$1,001 - $15,000</td>
            <td>
              
              <span class="green">6d</span>
              
            </td>
          </tr>
          
          <tr>
            <td class="muted">2025-06-16</td>
            <td><strong class="ticker">RBLX</strong></td>
            <td class="muted asset-cell" title="Roblox Corp">
              Roblox Corp
            </td>
            <td><span class="type-badge sell">SELL</span></td>
            <td class="muted">$1,001 - $15,000</td>
            <td>
              
              <span class="green">10d</span>
              
            </td>
          </tr>
          
          <tr>
            <td class="muted">2025-02-18</td>
            <td><strong class="ticker">YUM</strong></td>
            <td class="muted asset-cell" title="Yum! Brands Company: Yum (Louisville, KY) Description: Food">
              Yum! Brands Company: Yum (Louisvill…
            </td>
            <td><span class="type-badge sell">SELL</span></td>
            <td class="muted">$1,001 - $15,000</td>
            <td>
              
              <span class="green">19d</span>
              
            </td>
          </tr>
          
        </tbody>
      </table>
    </div>
    
  </div>

</main>

<footer class="footer">
  <div class="container">
    <p>Data: Official House Clerk PTR disclosures | InsiderFinance | Quiver Quantitative</p>
  </div>
</footer>

</body>
</html>